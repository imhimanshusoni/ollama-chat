# Tavily API key for the web_search tool (free tier: 1,000 searches/month at
# https://app.tavily.com). Vite inlines VITE_* vars into the client bundle at
# build time, so this is NOT a server secret — it ships in the published JS.
# Use a rate-limited personal key. Set the same var in the Vercel project's
# Environment Variables. If unset, web search is silently disabled.
VITE_TAVILY_API_KEY=
